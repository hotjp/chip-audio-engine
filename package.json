{
  "name": "chip-audio-engine",
  "version": "0.1.0",
  "description": "通用浏览器端音频引擎",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./packs/*": "./packs/*"
  },
  "files": [
    "dist",
    "packs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build:esm": "tsc",
    "build:umd": "tsc -p tsconfig.umd.json",
    "build": "npm run clean && npm run build:esm && cp dist/index.js dist/index.mjs && npm run build:umd",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "audio",
    "web-audio-api",
    "chip-audio",
    "chiptune",
    "sound-engine",
    "browser-audio"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {}
}
